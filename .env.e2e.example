# ActSix end-to-end test environment
# Copy to .env.e2e for local overrides.

E2E_PORT=3101
E2E_BASE_URL=http://127.0.0.1:3101

# Keep Sengo logic unchanged; point to simulator-backed bucket in later phases.
S3_BUCKET=deacon-care-system-e2e

# Test-only values
JWT_SECRET=actsix-e2e-secret
APP_NAME=ActSix E2E
GMAIL_FROM_ADDRESS=e2e@example.local
GMAIL_APP_PASSWORD=e2e-not-used
