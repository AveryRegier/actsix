{
  "name": "actsix",
  "version": "1.0.0",
  "description": "Tracking application for Deacon ministry",
  "type": "module",
  "main": "src/lambda.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage:check": "node scripts/check-coverage-thresholds.js",
    "e2e": "playwright test -c test/e2e/playwright.config.js",
    "e2e:smoke": "playwright test -c test/e2e/playwright.config.js --grep @smoke",
    "e2e:debug": "playwright test -c test/e2e/playwright.config.js --debug",
    "e2e:mcp": "npm run e2e && npm run e2e:artifacts",
    "e2e:mcp:smoke": "npm run e2e:smoke && npm run e2e:artifacts",
    "e2e:mcp:coverage": "npm run e2e:coverage && npm run e2e:artifacts",
    "e2e:artifacts": "node scripts/e2e-artifacts-manifest.js",
    "e2e:install": "playwright install chromium",
    "e2e:coverage:clean": "rimraf .coverage/e2e-browser .nyc_output coverage/e2e coverage/e2e-server",
    "e2e:coverage:run": "npm run e2e:coverage:clean && cross-env NODE_V8_COVERAGE=./.nyc_output playwright test -c test/e2e/playwright.config.js",
    "e2e:coverage:report": "node scripts/e2e-coverage-report.js && node scripts/e2e-server-coverage-report.js",
    "e2e:coverage": "npm run e2e:coverage:run && npm run e2e:coverage:report",
    "kill-port": "node scripts/kill-port.js",
    "dev": "npm run kill-port && node src/server.js",
    "build": "node scripts/build.js",
    "build:validate": "npm run test && npm run build",
    "start": "node src/server.js",
    "start:prod": "node dist/server.js",
    "lambda": "node src/lambda.js",
    "lambda:prod": "node dist/lambda.js",
    "clean": "rimraf coverage dist",
    "lint": "echo 'Linting would go here'",
    "validate": "npm run test && npm run lint",
    "deploy:prep": "npm run clean && npm run build:validate",
    "generate": "node scripts/generate_data.cjs",
    "migrate:locations": "node scripts/migrate-locations.js",
    "dist": "node scripts/dist.cjs",
    "deploy": "powershell.exe -File scripts/deploy-cloudformation.ps1"
  },
  "keywords": [
    "ministry",
    "tracking",
    "deacon",
    "shut-in",
    "care"
  ],
  "author": "Avery Regier <avery.regier@gmail.com> (https://github.com/AveryRegier)",
  "license": "Apache-2.0",
  "devDependencies": {
    "@hono/node-server": "^1.15.0",
    "@playwright/test": "^1.52.0",
    "@types/chance": "^1.1.7",
    "@types/node": "^24.0.13",
    "@vitest/coverage-v8": "^3.2.4",
    "archiver": "^7.0.1",
    "c8": "^10.1.3",
    "chance": "^1.1.13",
    "cross-env": "^7.0.3",
    "chrono-node": "^2.3.2",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "nyc": "^15.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "v8-to-istanbul": "^9.3.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.25.1",
    "@aws-sdk/client-cognito-identity-provider": "^3.873.0",
    "@aws-sdk/node-http-handler": "^3.370.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.11.0",
    "clox": "file:../clox/dist",
    "hono": "^4.8.4",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "nodemailer": "^7.0.10",
    "openid-client": "^6.8.1",
    "passport": "^0.7.0",
    "qs": "^6.14.0",
    "sengo": "file:../sengo/client/dist",
    "xlsx": "^0.18.5"
  }
}
